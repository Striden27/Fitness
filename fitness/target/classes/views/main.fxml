<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.MainController"
            style="-fx-background-color: #1a1a2e;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #16213e; -fx-padding: 0 24 0 0;">
            <Label text="💪 ФИТНЕС КЛУБ"
                   style="-fx-font-size: 18; -fx-font-weight: bold;
                          -fx-text-fill: #e94560; -fx-padding: 16 32 16 24;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="userLabel"
                   style="-fx-font-size: 13; -fx-text-fill: #c0c8d8; -fx-padding: 0 16 0 0;"/>
            <Button text="Выйти" onAction="#logout"
                    style="-fx-background-color: #e94560; -fx-text-fill: white;
                           -fx-font-size: 12; -fx-background-radius: 6;
                           -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="tabPane"
                 style="-fx-background-color: #1a1a2e; -fx-tab-min-width: 140;"
                 stylesheets="/styles/main.css">

            <Tab text="👤  Мой профиль" closable="false">
                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: #1a1a2e; -fx-background: #1a1a2e;">
                    <VBox spacing="20" style="-fx-padding: 32;">

                        <VBox spacing="16"
                              style="-fx-background-color: #16213e; -fx-background-radius: 12; -fx-padding: 28;">
                            <Label text="Личные данные"
                                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                            <GridPane hgap="16" vgap="12">
                                <Label text="Имя:" style="-fx-text-fill: #8892a4;"
                                       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <TextField fx:id="profileName"
                                           GridPane.columnIndex="1" GridPane.rowIndex="0"
                                           style="-fx-background-color: #0f3460; -fx-text-fill: white;
                                                  -fx-background-radius: 6; -fx-padding: 8 12 8 12;"
                                           prefWidth="280"/>
                                <Label text="Email:" style="-fx-text-fill: #8892a4;"
                                       GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label fx:id="profileEmail"
                                       style="-fx-text-fill: #c0c8d8; -fx-font-size: 13;"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                                <Label text="Телефон:" style="-fx-text-fill: #8892a4;"
                                       GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <TextField fx:id="profilePhone"
                                           GridPane.columnIndex="1" GridPane.rowIndex="2"
                                           style="-fx-background-color: #0f3460; -fx-text-fill: white;
                                                  -fx-background-radius: 6; -fx-padding: 8 12 8 12;"/>
                            </GridPane>
                            <HBox spacing="10">
                                <Button text="Сохранить изменения" onAction="#saveProfile"
                                        style="-fx-background-color: #e94560; -fx-text-fill: white;
                                               -fx-background-radius: 6; -fx-padding: 9 20 9 20;
                                               -fx-cursor: hand; -fx-font-size: 13;"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="16"
                              style="-fx-background-color: #16213e; -fx-background-radius: 12; -fx-padding: 28;">
                            <Label text="Сменить пароль"
                                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                                <PasswordField fx:id="oldPasswordField" promptText="Текущий пароль"
                                               prefWidth="220"
                                               style="-fx-background-color: #0f3460; -fx-text-fill: white;
                                                      -fx-prompt-text-fill: #8892a4; -fx-background-radius: 6;
                                                      -fx-padding: 8 12 8 12;"/>
                                <PasswordField fx:id="newPasswordField" promptText="Новый пароль"
                                               prefWidth="220"
                                               style="-fx-background-color: #0f3460; -fx-text-fill: white;
                                                      -fx-prompt-text-fill: #8892a4; -fx-background-radius: 6;
                                                      -fx-padding: 8 12 8 12;"/>
                                <Button text="Сменить" onAction="#changePassword"
                                        style="-fx-background-color: #0f3460; -fx-text-fill: #e94560;
                                               -fx-background-radius: 6; -fx-padding: 9 16 9 16; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="12"
                              style="-fx-background-color: #16213e; -fx-background-radius: 12; -fx-padding: 28;">
                            <Label text="Мой абонемент"
                                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e94560;"/>
                            <Label fx:id="membershipLabel"
                                   style="-fx-text-fill: #c0c8d8; -fx-font-size: 14;"/>
                            <Label fx:id="membershipDatesLabel"
                                   style="-fx-text-fill: #8892a4; -fx-font-size: 13;"/>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </Tab>

            <Tab text="🏋  Расписание" closable="false" onSelectionChanged="#onTrainingsTab">
                <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #1a1a2e;">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField" promptText="Поиск по названию..."
                                   prefWidth="300"
                                   style="-fx-background-color: #16213e; -fx-text-fill: white;
                                          -fx-prompt-text-fill: #8892a4; -fx-background-radius: 8;
                                          -fx-padding: 10 16 10 16; -fx-font-size: 13;"/>
                        <Button text="Найти" onAction="#searchTrainings"
                                style="-fx-background-color: #e94560; -fx-text-fill: white;
                                       -fx-background-radius: 8; -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
                        <Button text="Все" onAction="#loadTrainings"
                                style="-fx-background-color: #0f3460; -fx-text-fill: #c0c8d8;
                                       -fx-background-radius: 8; -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Записаться" onAction="#bookTraining"
                                style="-fx-background-color: #e94560; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-background-radius: 8;
                                       -fx-padding: 10 24 10 24; -fx-cursor: hand;"/>
                    </HBox>
                    <TableView fx:id="trainingsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #16213e; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="tTitleCol"   text="Тренировка" prefWidth="200"/>
                            <TableColumn fx:id="tTrainerCol" text="Тренер"     prefWidth="160"/>
                            <TableColumn fx:id="tDateCol"    text="Дата"       prefWidth="110"/>
                            <TableColumn fx:id="tTimeCol"    text="Время"      prefWidth="80"/>
                            <TableColumn fx:id="tSlotsCol"   text="Места"      prefWidth="90"/>
                            <TableColumn fx:id="tDescCol"    text="Описание"   prefWidth="220"/>
                        </columns>
                        <placeholder>
                            <Label text="Нет доступных тренировок" style="-fx-text-fill: #8892a4;"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>

            <Tab text="📋  Мои записи" closable="false" onSelectionChanged="#onBookingsTab">
                <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #1a1a2e;">
                    <TableView fx:id="bookingsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: #16213e; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="bTitleCol"   text="Тренировка" prefWidth="220"/>
                            <TableColumn fx:id="bTrainerCol" text="Тренер"     prefWidth="160"/>
                            <TableColumn fx:id="bDateCol"    text="Дата"       prefWidth="110"/>
                            <TableColumn fx:id="bTimeCol"    text="Время"      prefWidth="80"/>
                            <TableColumn fx:id="bStatusCol"  text="Статус"     prefWidth="100"/>
                        </columns>
                        <placeholder>
                            <Label text="У вас нет активных записей" style="-fx-text-fill: #8892a4;"/>
                        </placeholder>
                    </TableView>
                    <HBox>
                        <Button text="Отменить запись" onAction="#cancelBooking"
                                style="-fx-background-color: #e94560; -fx-text-fill: white;
                                       -fx-background-radius: 8; -fx-padding: 10 24 10 24; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>