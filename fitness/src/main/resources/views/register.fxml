<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.RegisterController"
      alignment="CENTER" spacing="0"
      style="-fx-background-color: #1a1a2e;">

    <VBox alignment="CENTER" spacing="20"
          style="-fx-background-color: #16213e; -fx-background-radius: 16;
                 -fx-padding: 40 56 40 56; -fx-effect: dropshadow(gaussian, #000, 24, 0.4, 0, 4);"
          maxWidth="420">

        <VBox alignment="CENTER" spacing="6">
            <Label text="💪" style="-fx-font-size: 36;"/>
            <Label text="РЕГИСТРАЦИЯ"
                   style="-fx-font-size: 20; -fx-font-weight: bold;
                          -fx-text-fill: #e94560; -fx-letter-spacing: 2;"/>
        </VBox>

        <VBox spacing="10">
            <TextField fx:id="fullNameField" promptText="Полное имя"
                       style="-fx-background-color: #0f3460; -fx-text-fill: white;
                              -fx-prompt-text-fill: #8892a4; -fx-background-radius: 8;
                              -fx-padding: 12 16 12 16; -fx-font-size: 13;"/>
            <TextField fx:id="emailField" promptText="Email (@gmail.com или @yandex.ru)"
                       style="-fx-background-color: #0f3460; -fx-text-fill: white;
                              -fx-prompt-text-fill: #8892a4; -fx-background-radius: 8;
                              -fx-padding: 12 16 12 16; -fx-font-size: 13;"/>
            <TextField fx:id="phoneField" promptText="Телефон (+7...)"
                       style="-fx-background-color: #0f3460; -fx-text-fill: white;
                              -fx-prompt-text-fill: #8892a4; -fx-background-radius: 8;
                              -fx-padding: 12 16 12 16; -fx-font-size: 13;"/>
            <PasswordField fx:id="passwordField" promptText="Пароль (мин. 8 символов + цифра)"
                           style="-fx-background-color: #0f3460; -fx-text-fill: white;
                                  -fx-prompt-text-fill: #8892a4; -fx-background-radius: 8;
                                  -fx-padding: 12 16 12 16; -fx-font-size: 13;"/>
        </VBox>

        <VBox spacing="10">
            <Button text="ЗАРЕГИСТРИРОВАТЬСЯ" onAction="#register" maxWidth="Infinity"
                    style="-fx-background-color: #e94560; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13;
                           -fx-background-radius: 8; -fx-padding: 12 0 12 0; -fx-cursor: hand;"/>
            <Button text="Уже есть аккаунт? Войти" onAction="#goToLogin" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #8892a4;
                           -fx-font-size: 12; -fx-cursor: hand; -fx-border-width: 0;"/>
        </VBox>
    </VBox>
</VBox>